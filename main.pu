import os
import json
import random
from aiogram import Bot, Dispatcher, types
from aiogram.utils import executor
from aiogram.types import ReplyKeyboardMarkup
from aiogram.dispatcher import FSMContext
from aiogram.dispatcher.filters.state import State, StatesGroup
from aiogram.contrib.fsm_storage.memory import MemoryStorage

TOKEN = os.getenv("TOKEN")

bot = Bot(token=TOKEN)
dp = Dispatcher(bot, storage=MemoryStorage())

FILE = "data.json"
users = {}
games = {"bets": []}

# ================= FSM =================

class GameState(StatesGroup):
    roulette = State()
    mines = State()
    joker = State()

# ================= UI =================

menu = ReplyKeyboardMarkup(resize_keyboard=True)
menu.add("💰 Баланс", "🎲 Рулетка")
menu.add("💣 Мины", "🃏 Джокер")
menu.add("🏆 Бонус", "❌ Отмена")

# ================= DATA =================

def load():
    global users
    try:
        users = json.load(open(FILE))
    except:
        users = {}

def save():
    json.dump(users, open(FILE, "w"), indent=2)

def u(uid):
    uid = str(uid)
    if uid not in users:
        users[uid] = {"balance": 0, "bonus": False}
    return users[uid]

# ================= CANCEL =================

@dp.message_handler(lambda m: m.text == "❌ Отмена", state="*")
async def cancel(m: types.Message, state: FSMContext):
    await state.finish()
    await m.answer("❌ действие отменено", reply_markup=menu)

# ================= START =================

@dp.message_handler(commands=["start"])
async def start(m: types.Message):
    user = u(m.from_user.id)

    if user["balance"] == 0:
        user["balance"] = 5000

    save()

    await m.answer(
        f"🎰 FAREYN CASINO\n\n💰 {user['balance']} FRN\n\nВыбери игру 👇",
        reply_markup=menu
    )

# ================= BALANCE =================

@dp.message_handler(lambda m: m.text == "💰 Баланс")
async def balance(m: types.Message):
    await m.answer(f"💰 {u(m.from_user.id)['balance']} FRN")

# ================= BONUS =================

@dp.message_handler(lambda m: m.text == "🏆 Бонус")
async def bonus(m: types.Message):
    user = u(m.from_user.id)

    if user["bonus"]:
        return await m.answer("❌ уже получено")

    user["bonus"] = True
    user["balance"] += 10000
    save()

    await m.answer("🎁 +10000 FRN")

# ================= ROULETTE =================

@dp.message_handler(lambda m: m.text == "🎲 Рулетка")
async def roulette_start(m: types.Message):
    await GameState.roulette.set()
    await m.answer("🎲 Введи: число ставка\nпример: 17 100")

@dp.message_handler(state=GameState.roulette)
async def roulette_bet(m: types.Message, state: FSMContext):
    parts = m.text.split()

    if len(parts) != 2:
        return await m.answer("❌ формат: 17 100")

    if not parts[0].isdigit() or not parts[1].isdigit():
        return await m.answer("❌ только числа")

    num = int(parts[0])
    amount = int(parts[1])

    if num < 0 or num > 36:
        return await m.answer("❌ число 0-36")

    if amount <= 0:
        return await m.answer("❌ ставка > 0")

    user = u(m.from_user.id)

    if user["balance"] < amount:
        return await m.answer("❌ нет денег")

    user["balance"] -= amount
    games["bets"].append((m.from_user.id, num, amount))
    save()

    await state.finish()
    await m.answer("✅ ставка принята\nнажми /go")

@dp.message_handler(commands=["go"])
async def go(m: types.Message):
    if not games["bets"]:
        return await m.answer("❌ нет ставок")

    await m.answer_animation("https://media.tenor.com/4nXK3X9x8kAAAAAC/casino-roulette.gif")

    win = random.randint(0, 36)
    text = f"🎯 ВЫПАЛО: {win}\n\n"

    for uid, num, amount in games["bets"]:
        user = u(uid)

        try:
            name = (await bot.get_chat(uid)).first_name
        except:
            name = "Игрок"

        if num == win:
            prize = amount * 35
            user["balance"] += prize
            text += f"✅ {name} +{prize}\n"
        else:
            text += f"❌ {name} -{amount}\n"

    games["bets"] = []
    save()

    await m.answer(text)

# ================= MINES =================

@dp.message_handler(lambda m: m.text == "💣 Мины")
async def mines_start(m: types.Message):
    await GameState.mines.set()
    await m.answer("💣 Введи ставку")

@dp.message_handler(state=GameState.mines)
async def mines_game(m: types.Message, state: FSMContext):
    user = u(m.from_user.id)

    data = await state.get_data()

    # первый ввод = ставка
    if "bet" not in data:
        if not m.text.isdigit():
            return await m.answer("❌ число")

        bet = int(m.text)

        if user["balance"] < bet:
            return await m.answer("❌ нет денег")

        user["balance"] -= bet

        await state.update_data(
            bet=bet,
            mult=1.0,
            bombs=set(random.sample(range(20), 5))
        )

        save()
        return await m.answer("💣 игра началась\nчисло 0-19 или cash")

    data = await state.get_data()

    if m.text == "cash":
        win = int(data["bet"] * data["mult"])
        user["balance"] += win
        save()
        await state.finish()
        return await m.answer(f"💰 +{win}")

    if not m.text.isdigit():
        return

    x = int(m.text)

    if x in data["bombs"]:
        await state.finish()
        return await m.answer("💥 проигрыш")

    data["mult"] *= 1.3
    await state.update_data(mult=data["mult"])

    await m.answer(f"✨ x{data['mult']:.2f}")

# ================= JOKER =================

@dp.message_handler(lambda m: m.text == "🃏 Джокер")
async def joker_start(m: types.Message):
    await GameState.joker.set()
    await m.answer("🃏 Введи ставку")

@dp.message_handler(state=GameState.joker)
async def joker_game(m: types.Message, state: FSMContext):
    user = u(m.from_user.id)
    data = await state.get_data()

    if "bet" not in data:
        if not m.text.isdigit():
            return await m.answer("❌ число")

        bet = int(m.text)

        if user["balance"] < bet:
            return await m.answer("❌ нет денег")

        user["balance"] -= bet

        await state.update_data(bet=bet, mult=1.0)
        save()

        return await m.answer("🃏 напиши play или cash")

    data = await state.get_data()

    if m.text == "cash":
        win = int(data["bet"] * data["mult"])
        user["balance"] += win
        save()
        await state.finish()
        return await m.answer(f"💰 +{win}")

    if m.text != "play":
        return

    if random.randint(1, 100) < 30:
        await state.finish()
        return await m.answer("💀 проигрыш")

    data["mult"] *= 1.33
    await state.update_data(mult=data["mult"])

    await m.answer(f"✨ x{data['mult']:.2f}")

# ================= RUN =================

if __name__ == "__main__":
    load()
    executor.start_polling(dp)
